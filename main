  <style>
    :root {
      color-scheme: dark;
      font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      --bg: #0b1120;
      --bg-top: #111a2e;
      --card: #162033;
      --text: #e6edf7;
      --muted: #9fb0c8;
      --accent: #6ea8fe;
      --accent-soft: #1d3357;
      --border: #2a3b57;
      --good: #5ee2a0;
      --input-bg: #0f1728;
      --shadow: rgba(0, 0, 0, 0.35);
    }

    * { box-sizing: border-box; }
    body {
      margin: 0;
      min-height: 100vh;
      background: radial-gradient(circle at top, var(--bg-top) 0%, var(--bg) 60%, #070b14 100%);
      color: var(--text);
    }

    .layout {
      width: min(1080px, calc(100% - 2rem));
      margin: 2rem auto;
      display: grid;
      gap: 1.5rem;
      grid-template-columns: repeat(auto-fit, minmax(310px, 1fr));
      align-items: start;
    }

    .panel {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 18px;
      padding: 1.25rem;
      box-shadow: 0 18px 45px var(--shadow);
    }

    h1, h2, h3, p { margin-top: 0; }
    h1 { font-size: clamp(1.8rem, 2vw, 2.5rem); margin-bottom: 0.5rem; }
